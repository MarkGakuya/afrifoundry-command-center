# AfriFoundry Command Center — Environment Variables
# Copy this to .env.local and fill in your values

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-here

# Local admin credentials (fallback when API is unreachable)
ADMIN_EMAIL=mark@afrifoundry.com
ADMIN_PASSWORD=your-secure-password-here

# ── API ───────────────────────────────────────────────────────────────────────
# AfriFoundry backend API base URL
API_BASE=https://afrifoundry-api.onrender.com

# Bearer token for API authentication (your admin API token)
API_TOKEN=your-api-token-here

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://command.afrifoundry.com
